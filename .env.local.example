NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional but recommended — instant signup with no email confirmation (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI (server-only — never commit real keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# openrouter | gemini
AI_PROVIDER=
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Question Factory uses store_factory_questions RPC (run supabase/migrations/20250527120000_question_factory.sql)
